# LLM Provider: "openai" or "qwen"
LLM_PROVIDER=qwen

# API Key (DashScope key for Qwen, OpenAI key for GPT-4o)
LLM_API_KEY=sk-your-dashscope-api-key

# Base URL (Qwen DashScope default, change for other providers)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model name
LLM_MODEL=qwen-plus

# Legacy OpenAI config (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o

# Set to false to use real LLM calls
USE_MOCK_LLM=true

# Chunking
CHUNK_MAX_TOKENS=1000
CHUNK_OVERLAP_TOKENS=100
